            {% if post.data.cover %}<div class="idea-card__img" style="background-image:url('{{ post.data.cover }}')"></div>{% endif %}
            <div class="idea-card__body">
              <span class="idea-card__tag">{{ post.data.categoria }}</span>
              <h3>{{ post.data.title }}</h3>
              <p>{{ post.data.description }}</p>
              <div class="idea-card__meta"><span>{{ post.date | fechaLarga }}</span><span>Leer →</span></div>
            </div>
          </a>
          {% endif %}{% endfor %}
        </div>
        <p style="margin-top:32px;"><a href="/blog.html" class="btn btn--outline">Ver todas las ideas →</a></p>
