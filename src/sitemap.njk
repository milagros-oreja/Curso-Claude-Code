---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url><loc>{{ site.url }}/</loc><changefreq>weekly</changefreq><priority>1.0</priority></url>
  <url><loc>{{ site.url }}/milagros-oreja.html</loc><changefreq>monthly</changefreq><priority>0.9</priority></url>
  <url><loc>{{ site.url }}/cursos.html</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ site.url }}/blog.html</loc><changefreq>weekly</changefreq><priority>0.7</priority></url>
  {%- for post in collections.articulos %}
  <url><loc>{{ site.url }}{{ post.url }}</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  {%- endfor %}
</urlset>
