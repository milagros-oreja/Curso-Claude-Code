---
permalink: /blog.html
eleventyExcludeFromCollections: true
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blog &middot; Historias en construcci&oacute;n &mdash; BRCOM</title>
  <meta name="description" content="Ideas y aprendizajes sobre relaciones p&uacute;blicas, inteligencia artificial y posicionamiento de marca, por Milagros Oreja." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href="{{ site.url }}/blog.html" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

  <!-- NAV -->
  <header class="nav">
    <div class="nav__inner">
      <a href="/" class="logo">BRCOM<span>.</span></a>
      <button class="nav__toggle" aria-label="Abrir menú" aria-expanded="false"><span></span><span></span><span></span></button>
      <nav class="nav__links">
        <a href="/#firma">La firma</a>
        <a href="/#metodo">Cómo trabajamos</a>
        <a href="/#pilares">Pilares</a>
        <a href="/blog.html">Ideas</a>
        <a href="/milagros-oreja.html">Fundadora</a>
        <a href="/#contacto" class="btn btn--primary">Hablemos</a>
      </nav>
    </div>
  </header>

  <main>
    <!-- HERO -->
    <section class="blog-hero">
      <p class="eyebrow">Blog &middot; Historias en construcci&oacute;n</p>
      <h1 class="hero__title">Ideas, <span class="ital">reputaci&oacute;n</span><br />y <span class="ital">visibilidad.</span></h1>
      <p class="hero__sub">An&aacute;lisis y aprendizajes sobre relaciones p&uacute;blicas, inteligencia artificial y posicionamiento de marca, por Milagros Oreja.</p>
    </section>

    <!-- ARTICULOS -->
    <section class="section">
      <p class="services__label">&Uacute;ltimos art&iacute;culos</p>
      <div class="blog-grid">
        {% for post in collections.articulos %}
        <article class="blog-card">
          <a href="{{ post.url }}" style="text-decoration:none;color:inherit;">
            {% if post.data.cover %}
            <div class="blog-card__img" style="background-image:url('{{ post.data.cover }}')"></div>
            {% endif %}
            <div class="blog-card__body">
              <span class="blog-card__tag">{{ post.data.categoria }}</span>
              <h3>{{ post.data.title }}</h3>
              <p>{{ post.data.description }}</p>
              <div class="blog-card__meta"><span>{{ post.date | fechaLarga }}</span><span>Leer &rarr;</span></div>
            </div>
          </a>
        </article>
        {% endfor %}
      </div>
    </section>

    <!-- CTA SUBSTACK -->
    <section class="cta">
      <h2 class="cta__title">Lee <span class="ital">Historias en construcci&oacute;n.</span></h2>
      <p class="cta__sub">Tambi&eacute;n puedes seguir el Substack de Milagros Oreja. Suscr&iacute;bete gratis.</p>
      <a href="https://milagrosoreja.substack.com" target="_blank" rel="noopener" class="btn btn--primary">Ir al Substack &rarr;</a>
    </section>
  </main>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer__inner">
      <div>
        <span class="logo logo--small">BRCOM<span>.</span></span>
        <p class="footer__tag">Reputaci&oacute;n e inteligencia de audiencias. Construimos reputaci&oacute;n para que te elijan las personas y para que te recomienden las m&aacute;quinas.</p>
      </div>
      <div>
        <h4>Firma</h4>
        <a href="/#firma">La firma</a>
        <a href="/#metodo">Cómo trabajamos</a>
        <a href="/#ia">Reputaci&oacute;n en IA</a>
        <a href="/#pilares">Pilares</a>
        <a href="/blog.html">Ideas</a>
      </div>
      <div>
        <h4>Contacto</h4>
        <a href="/#contacto">Agendar conversaci&oacute;n</a>
        <a href="mailto:milagros@brcom.mx">milagros@brcom.mx</a>
        <a href="/milagros-oreja.html">Fundadora</a>
        <a href="https://www.linkedin.com/in/milagros-oreja" target="_blank" rel="noopener">LinkedIn</a>
      </div>
    </div>
    <div class="footer__bottom">&copy; 2026 BRCOM &middot; Reputaci&oacute;n e inteligencia de audiencias</div>
  </footer>

  <!-- MODAL FORMULARIO -->
  <div class="modal" id="modal" aria-hidden="true">
    <div class="modal__overlay" data-close-form></div>
    <div class="modal__panel" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
      <button class="modal__close" data-close-form aria-label="Cerrar">&times;</button>
      <h2 class="modal__title" id="modalTitle">Hablemos.</h2>
      <p class="modal__sub">D&eacute;janos tus datos y te contactamos en menos de 24 horas.</p>
      <form class="form" id="contactForm">
        <label><span>Nombre</span><input type="text" name="nombre" required placeholder="Tu nombre" /></label>
        <label><span>Correo</span><input type="email" name="email" required placeholder="tu@correo.com" /></label>
        <label><span>Empresa</span><input type="text" name="empresa" placeholder="Tu marca o empresa" /></label>
        <label><span>Mensaje</span><textarea name="mensaje" rows="3" placeholder="Cu&eacute;ntanos tu objetivo"></textarea></label>
        <button type="submit" class="btn btn--primary btn--full">Enviar</button>
        <p class="form__success" id="formSuccess">Gracias. Hemos recibido tu mensaje.</p>
      </form>
    </div>
  </div>

  <script src="/script.js"></script>
</body>
</html>
